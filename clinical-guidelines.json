    {
      "id": "g_orvi",
      "title": "Острая респираторная вирусная инфекция",
      "keywords": ["температура", "кашель", "насморк", "боль в горле", "простуда", "орви", "грипп", "озноб", "слабость", "ломота"],
      "source_id": "minzdrav_orvi_2023",
      "symptoms": {
        "typical": ["Температура 37.5-39°C", "Кашель (сухой или влажный)", "Насморк, заложенность носа", "Боль в горле", "Слабость, ломота в теле"],
        "red_flags": ["Температура выше 39.5°C более 3 дней", "Одышка в покое", "Боль в груди при дыхании", "Кровохарканье", "Спутанность сознания"]
      },
      "actions": {
        "home": ["Обильное тёплое питьё (2-3 л/сут)", "Постельный режим", "Парацетамол/ибупрофен при температуре выше 38.5°C", "Солевые растворы для промывания носа", "Проветривание помещения"],
        "avoid": ["Антибиотики без назначения врача (на вирусы не действуют)", "Жаропонижающие при температуре ниже 38.5°C", "Алкоголь", "Перегревание (бани, горячие ванны)"],
        "see_doctor": ["Если температура держится более 5 дней", "При появлении одышки", "При ухудшении после улучшения ('вторая волна')"]
      },
      "special_groups": {"elderly": "Выше риск осложнений — консультация терапевта в первые 24-48 часов", "children": "У детей до 3 лет — обязательный вызов педиатра", "pregnant": "Многие препараты запрещены — только парацетамол, консультация акушера"},
      "reassurance": "ОРВИ обычно проходит за 7-10 дней без осложнений. Большинство случаев лечится дома.",
      "urgency": "plan"
    },
    {
      "id": "g_hypertension",
