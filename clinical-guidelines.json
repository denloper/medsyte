      "actions": {
        "home": ["Измерять давление 2 раза в день", "Вести дневник давления", "Ограничение соли до 5 г/сут", "Физическая активность 150 мин/нед", "Отказ от курения и алкоголя"],
        "avoid": ["Самостоятельно менять дозу препаратов", "Прекращать приём назначенных лекарств", "Кофеин в больших количествах"],
